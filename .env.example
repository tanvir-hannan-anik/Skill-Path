# SkillPath environment configuration.
# Copy this file to `.env.local` and fill in real values.
# All VITE_* variables are exposed to the browser. NEVER put server-only secrets here.

# --- Firebase (https://console.firebase.google.com -> Project settings -> Web app config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Gemini API key (https://aistudio.google.com/app/apikey)
# DEV ONLY: exposing this in the browser is acceptable for prototyping but in
# production you MUST proxy Gemini calls through a backend (Cloud Function or
# Express server) and remove this var. See README.md for the migration path.
VITE_GEMINI_API_KEY=

# --- YouTube Data API v3 (https://console.cloud.google.com -> APIs & Services)
# Required for in-app video search. Free tier: 10,000 quota units/day (~100
# search queries). Same browser-exposure caveat as the Gemini key applies.
# Optional: leave blank to fall back to manual URL paste.
VITE_YOUTUBE_API_KEY=

# --- Google Drive API key (https://console.cloud.google.com -> APIs & Services)
# Used to resolve Drive file titles from share URLs in the Plan page.
VITE_GOOGLE_DRIVE_API_KEY=

# --- Groq API key (https://console.groq.com/keys)
# Powers the AI assistant chat in Insights. Free tier available.
VITE_GROQ_API_KEY=

# --- Supabase (https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
